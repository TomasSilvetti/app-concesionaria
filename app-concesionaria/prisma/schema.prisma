generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../docs/erd.svg"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id
  clienteId String
  nombre    String
  creadoEn  DateTime  @default(now())
  Client    Client    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  Expense   Expense[]

  @@unique([clienteId, nombre])
  @@index([clienteId])
}

model Client {
  id              String            @id
  nombre          String
  activo          Boolean           @default(true)
  modulos         Json
  creadoEn        DateTime          @default(now())
  actualizadoEn   DateTime
  Category        Category[]
  Expense         Expense[]
  Operation       Operation[]
  OperationType   OperationType[]
  Origin          Origin[]
  Pago            Pago[]
  PaymentMethod   PaymentMethod[]
  Pendiente       Pendiente[]
  User            User[]
  VehicleBrand    VehicleBrand[]
  VehicleCategory VehicleCategory[]
}

model Expense {
  id            String     @id
  clienteId     String
  operacionId   String?
  fecha         DateTime   @default(now())
  descripcion   String
  categoriaId   String
  monto         Float
  origenId      String
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt
  Category      Category   @relation(fields: [categoriaId], references: [id])
  Client        Client     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  Operation     Operation? @relation(fields: [operacionId], references: [id])
  Origin        Origin     @relation(fields: [origenId], references: [id])

  @@index([categoriaId])
  @@index([clienteId])
  @@index([operacionId])
  @@index([origenId])
}

model Operation {
  id                String              @id
  idOperacion       String
  clienteId         String
  nombreComprador   String
  fechaInicio       DateTime
  fechaVenta        DateTime?
  vehiculoVendidoId String
  precioVentaTotal  Float
  ingresosBrutos    Float
  comision          Float
  gastosAsociados   Float               @default(0)
  ingresosNetos     Float
  precioToma        Float?
  estado            String              @default("open")
  creadoEn          DateTime            @default(now())
  actualizadoEn     DateTime
  marcaId           String
  categoriaId       String
  tipoOperacionId   String
  diasVenta         Int?
  Expense           Expense[]
  Pago              Pago[]
  VehicleCategory   VehicleCategory     @relation(fields: [categoriaId], references: [id])
  Client            Client              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  VehicleBrand      VehicleBrand        @relation(fields: [marcaId], references: [id])
  OperationType     OperationType       @relation(fields: [tipoOperacionId], references: [id])
  VehiculoVendido   Vehicle             @relation("VehiculosVendidos", fields: [vehiculoVendidoId], references: [id], onDelete: Cascade)
  OperationExchange OperationExchange[]
  OperationDocument OperationDocument?
  Vehicle           Vehicle[]

  @@unique([clienteId, idOperacion])
  @@index([categoriaId])
  @@index([clienteId])
  @@index([estado])
  @@index([marcaId])
  @@index([tipoOperacionId])
  @@index([vehiculoVendidoId])
}

model OperationDocument {
  id            String    @id
  operacionId   String    @unique
  nombreArchivo String
  mimeType      String
  datos         Bytes
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime
  Operation     Operation @relation(fields: [operacionId], references: [id], onDelete: Cascade)
}

model OperationExchange {
  id              String    @id
  operacionId     String
  stockId         String
  precioNegociado Float?
  creadoEn        DateTime  @default(now())
  actualizadoEn   DateTime
  Operation       Operation @relation(fields: [operacionId], references: [id], onDelete: Cascade)
  Vehicle         Vehicle   @relation(fields: [stockId], references: [id])

  @@unique([operacionId, stockId])
  @@index([operacionId])
  @@index([stockId])
}

model OperationType {
  id        String      @id
  clienteId String
  nombre    String
  creadoEn  DateTime    @default(now())
  Operation Operation[]
  Client    Client      @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, nombre])
  @@index([clienteId])
}

model Origin {
  id        String    @id
  clienteId String
  nombre    String
  creadoEn  DateTime  @default(now())
  Expense   Expense[]
  Client    Client    @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, nombre])
  @@index([clienteId])
}

model User {
  id            String   @id
  username      String   @unique
  email         String?
  nombre        String
  password      String
  rol           String   @default("usuario")
  clienteId     String?
  permisos      Json?
  activo               Boolean  @default(true)
  creadoEn             DateTime @default(now())
  actualizadoEn        DateTime
  Client               Client?  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  @@index([clienteId])
  @@index([username])
}

model Vehicle {
  id                String              @id
  operacionId       String?
  clienteId         String
  marcaId           String
  modelo            String
  anio              Int
  categoriaId       String
  patente           String?
  version           String?
  color             String?
  kilometros        Int?
  notasMecanicas    String?
  notasGenerales    String?
  precioRevista     Float?
  precioOferta      Float?
  estado            String              @default("disponible")
  creadoEn          DateTime            @default(now())
  actualizadoEn     DateTime
  OperationExchange OperationExchange[]
  VehicleCategory   VehicleCategory     @relation(fields: [categoriaId], references: [id])
  VehicleBrand      VehicleBrand        @relation(fields: [marcaId], references: [id])
  Operation         Operation?          @relation(fields: [operacionId], references: [id], onDelete: Cascade)
  VehiclePhoto      VehiclePhoto[]
  OperacionesVenta  Operation[]         @relation("VehiculosVendidos")

  @@index([categoriaId])
  @@index([clienteId])
  @@index([marcaId])
  @@index([operacionId])
}

model VehicleBrand {
  id            String      @id
  clienteId     String
  nombre        String
  creadoEn      DateTime    @default(now())
  actualizadoEn DateTime
  Operation     Operation[]
  Vehicle       Vehicle[]
  Client        Client      @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, nombre])
  @@index([clienteId])
}

model VehicleCategory {
  id        String      @id
  clienteId String
  nombre    String
  creadoEn  DateTime    @default(now())
  Operation Operation[]
  Vehicle   Vehicle[]
  Client    Client      @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, nombre])
  @@index([clienteId])
}

model Pendiente {
  id            String   @id
  clienteId     String
  nombreCliente String
  detalle       String
  completado    Boolean  @default(false)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime
  Client        Client   @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
}

model VehiclePhoto {
  id            String   @id
  stockId       String
  nombreArchivo String
  mimeType      String
  datos         Bytes
  orden         Int      @default(0)
  creadoEn      DateTime @default(now())
  Vehicle       Vehicle  @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
}

model PaymentMethod {
  id        String   @id
  clienteId String
  nombre    String
  creadoEn  DateTime @default(now())
  Client    Client   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  Pago      Pago[]

  @@unique([clienteId, nombre])
  @@index([clienteId])
}

model Pago {
  id            String        @id
  operacionId   String
  clienteId     String
  fecha         DateTime
  metodoPagoId  String
  monto         Float
  nota          String?
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime
  Client        Client        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  Operation     Operation     @relation(fields: [operacionId], references: [id], onDelete: Cascade)
  PaymentMethod PaymentMethod @relation(fields: [metodoPagoId], references: [id])

  @@index([clienteId])
  @@index([metodoPagoId])
  @@index([operacionId])
}
